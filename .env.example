# Copy to .env at the repository root and fill in secrets.
# Required for ./release.sh (except --dry-run and --rollback).

GITHUB_REPO=dadoonet/fscrawler

# Ionos SMTP (see https://www.ionos.fr/assistance/email/...)
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=465
# Optional: ssl (default on 465) or starttls (default on 587)
# SMTP_SECURITY=ssl
SMTP_USER=david@pilato.fr
# Quote the password if it contains #, $, or spaces
SMTP_PASS='your-mailbox-password'
ANNOUNCE_FROM=david@pilato.fr
# Local testing: your personal address
ANNOUNCE_TO=david@pilato.fr
# Production: discuss forums
# ANNOUNCE_TO=discuss+community-plugins@elastic.co

# Test SMTP login without sending:
#   python3 scripts/send-announcement.py --check-smtp
